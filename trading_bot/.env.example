# T-Bank (ex-Tinkoff) Invest API credentials. Copy to .env and fill in.
# Never commit .env. Never put these in config.yaml (SPEC 5).

# API token from https://www.tbank.ru/invest/settings/ (Invest API section).
TBANK_TOKEN=t.your_token_here

# Trading account id (the numeric/uuid account to trade on).
TBANK_ACCOUNT_ID=your_account_id_here
